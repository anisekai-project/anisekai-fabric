                "north": { "uv": [ 0, 0, 16, 2 ], "texture": "#face" },
                "east":  { "uv": [ 0, 0, 16, 2 ], "texture": "#face" },
                "south": { "uv": [ 0, 0, 16, 2 ], "texture": "#face" },
                "west":  { "uv": [ 0, 0, 16, 2 ], "texture": "#face" },
                "up":    { "uv": [ 0, 0, 16, 16 ], "texture": "#face" },
