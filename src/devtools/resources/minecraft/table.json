                "south": { "uv": [ 0, 0, 6, 1 ], "texture": "#support" },
                "west":  { "uv": [ 0, 0, 6, 1 ], "texture": "#support" },
                "up":    { "uv": [ 0, 0, 6, 6 ], "texture": "#support" },
                "down":  { "uv": [ 0, 0, 6, 6 ], "texture": "#support" }
              }
