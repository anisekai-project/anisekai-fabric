{
  "settings": {
    "usingVariants": [
      {
        "name": "woods",
        "maps": {
          "texture:support": "{{log}}",
          "texture:face":    "{{planks}}",
          "craft:support":   "minecraft:{{fence}}",
          "craft:foot":      "minecraft:{{slab}}",
          "craft:face":      "{{mod}}:{{type}}_half_slab"
        }
      }
    ]
  },
  "elements": {
    "item":        {
      "parent": "{{mod}}:block/{{item}}"
    },
    "tags":        [
      { "namespace": "{{mod}}", "value": "item/{{name}}s" },
      { "namespace": "minecraft", "value": "block/mineable/axe" }
    ],
    "loot_table":  {
      "type":  "minecraft:block",
      "pools": [
        {
          "rolls":      1,
          "entries":    [ { "type": "minecraft:item", "name": "{{id}}" } ],
          "conditions": [ { "condition": "minecraft:survives_explosion" } ]
        }
      ]
    },
    "blockstates": {
      "variants": {
        "facing=north": { "model": "{{mod}}:block/{{item}}", "uvlock": false },
        "facing=east":  { "model": "{{mod}}:block/{{item}}", "uvlock": false, "y": 90 },
        "facing=south": { "model": "{{mod}}:block/{{item}}", "uvlock": false, "y": 180 },
        "facing=west":  { "model": "{{mod}}:block/{{item}}", "uvlock": false, "y": 270 }
      }
    },
    "recipe":      {
      "type":     "minecraft:crafting_shaped",
      "category": "building",
      "group":    "{{name}}s",
      "pattern":  [
        "TTT",
        " S ",
        " F "
      ],
      "key":      {
        "S": {
          "item": "{{craft:support}}"
        },
        "F": {
          "item": "{{craft:foot}}"
        },
        "T": {
          "item": "{{craft:face}}"
        }
      },
      "result":   { "id": "{{id}}", "count": 1 }
    },
    "models":      {
      "": {
