  "dynamic":  {
    "wood": {
      "settings": {
        "usingVariant": {
          "name": "woods",
          "maps": {
            "texture:structure": "{{log}}",
            "texture:back":      "{{planks}}",
            "texture:drawer":    "{{stripped_log}}",
            "craft:structure":   "{{namespace}}:{{type}}_half_slab",
            "craft:legs":        "minecraft:{{fence}}"
          }
        }
      },
      "files":    {
        "assets/{{namespace}}/blockstates/{{item}}.json":            {
          "multipart": [
            {
              "apply": { "model": "{{namespace}}:block/{{item}}", "uvlock": false },
              "when":  { "facing": "north" }
            },
            {
              "apply": { "model": "{{namespace}}:block/{{item}}", "uvlock": false, "y": 90 },
              "when":  { "facing": "east" }
            },
            {
              "apply": { "model": "{{namespace}}:block/{{item}}", "uvlock": false, "y": 180 },
              "when":  { "facing": "south" }
            },
            {
              "apply": { "model": "{{namespace}}:block/{{item}}", "uvlock": false, "y": 270 },
              "when":  { "facing": "west" }
            },
            {
              "apply": { "model": "{{namespace}}:block/{{item}}_feet_full", "uvlock": false },
              "when":  { "north": false, "east": false, "south": false, "west": false }
            },
            {
              "apply": { "model": "{{namespace}}:block/{{item}}_feet_side", "uvlock": false },
              "when":  { "north": false, "east": false, "south": true, "west": false }
            },
            {
              "apply": { "model": "{{namespace}}:block/{{item}}_feet_side", "uvlock": false, "y": 180 },
              "when":  { "north": true, "east": false, "south": false, "west": false }
            },
            {
              "apply": { "model": "{{namespace}}:block/{{item}}_feet_side", "uvlock": false, "y": 270 },
              "when":  { "north": false, "east": true, "south": false, "west": false }
            },
            {
              "apply": { "model": "{{namespace}}:block/{{item}}_feet_side", "uvlock": false, "y": 90 },
              "when":  { "north": false, "east": false, "south": false, "west": true }
            }
          ]
        },
        "assets/{{namespace}}/models/block/{{item}}.json":           {
          "parent":   "{{namespace}}:block/base/{{name}}",
          "textures": {
            "structure": "minecraft:block/{{texture:structure}}",
            "back":      "minecraft:block/{{texture:back}}",
            "drawer":    "minecraft:block/{{texture:drawer}}",
            "particle":  "minecraft:block/{{texture:structure}}"
          }
        },
        "assets/{{namespace}}/models/block/{{item}}_feet_full.json": {
          "parent":   "{{namespace}}:block/base/{{name}}_feet_full",
          "textures": {
            "structure": "minecraft:block/{{texture:structure}}",
            "particle":  "minecraft:block/{{texture:structure}}"
          }
        },
        "assets/{{namespace}}/models/block/{{item}}_feet_side.json": {
          "parent":   "{{namespace}}:block/base/{{name}}_feet_side",
          "textures": {
            "structure": "minecraft:block/{{texture:structure}}",
            "particle":  "minecraft:block/{{texture:structure}}"
          }
        },
        "assets/{{namespace}}/models/item/{{item}}.json":            {
          "parent": "{{namespace}}:block/{{item}}"
        },
        "data/{{namespace}}/loot_table/blocks/{{item}}.json":        {
          "type":  "minecraft:block",
          "pools": [
            {
              "rolls":      1,
              "entries":    [ { "type": "minecraft:item", "name": "{{id}}" } ],
              "conditions": [ { "condition": "minecraft:survives_explosion" } ]
            }
          ]
        },
        "data/{{namespace}}/recipe/blocks/{{item}}.json":            {
          "type":     "minecraft:crafting_shaped",
          "category": "building",
          "group":    "{{name}}s",
          "pattern":  [
            "---",
            "- -",
            "|-|"
          ],
          "key":      {
            "-": {
              "item": "{{craft:structure}}"
            },
            "|": {
              "item": "{{craft:legs}}"
            }
          },
          "result":   { "id": "{{id}}", "count": 1 }
        }
      },
      "tags":     [
        { "namespace": "{{namespace}}", "value": "item/wooden_{{name}}s" },
        { "namespace": "{{namespace}}", "value": "block/wooden_{{name}}s" },
        { "namespace": "minecraft", "value": "block/mineable/axe" }
